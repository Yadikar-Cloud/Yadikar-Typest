{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Yadikar-Typest",
  "version": "2.0.1",
  "identifier": "it.yadikar.typist",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../v2"
  },
  "app": {
    "windows": [
      {
        "title": "Yadikar Typest",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../v2/image/keyboard-32x32.png",
      "../v2/image/keyboard-64x64.png",
      "../v2/image/keyboard-128x128.png",
      "../v2/image/keyboard-256x256.png",
      "../v2/image/keyboard-512x512.ico"
    ]
  }
}
