{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Yadikar-Typest",
  "version": "2.0.1",
  "identifier": "it.yadikar.typist",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../v2"
  },
  "app": {
    "windows": [
      {
        "title": "Yadikar Typest",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
